<robot name="robotic_arm">
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename='package://your_package/meshes/base_link.dae'/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename='package://your_package/meshes/base_link_collision.dae'/>
      </geometry>
    </collision>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename='package://your_package/meshes/link1.dae'/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename='package://your_package/meshes/link1_collision.dae'/>
      </geometry>
    </collision>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="end_effector"/>
    <origin xyz="0 0 1" rpy="0 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>
  <link name="end_effector">
    <visual>
      <geometry>
        <mesh filename='package://your_package/meshes/end_effector.dae'/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename='package://your_package/meshes/end_effector_collision.dae'/>
      </geometry>
    </collision>
  </link>
  <ros2_control>
    <controller name="joint1_position_controller">
      <type>JointPositionController</type>
      <joint>joint1</joint>
    </controller>
    <controller name="joint2_position_controller">
      <type>JointPositionController</type>
      <joint>joint2</joint>
    </controller>
  </ros2_control>
</robot>